# Rust / Tauri
src-tauri/target/
src-tauri/gen/
# Cargo.lock IS committed (for reproducible release builds — pins every
# transitive dep so CI's three platforms build against the exact same
# graph the dev did, and re-running `cargo build` months later doesn't
# pull a silently-bumped sub-dep that breaks something).

# Build output
*.tsbuildinfo

# Environment
.env
.env.*

# OS files
Thumbs.db

# Temp files
whatisee.txt
continue.txt
*.7z
godot.log

# Local-only — design bundle copy + icon-regen artifacts
.claude/
src-tauri/icons/_backup/
src-tauri/icons/.icon-source.png

# Vitest coverage reports — regenerated on every `npm run qa:coverage`
coverage/

# Cygwin/MSYS bash crash dumps (left behind by some shells when a
# command segfaults). Not shipped, not useful in history.
*.stackdump
