{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "STS2 Mod Manager",
  "version": "1.8.6",
  "identifier": "com.sts2mm.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "STS2 Mod Manager",
        "width": 1100,
        "height": 700,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://staticdelivery.nexusmods.com; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "app",
      "dmg",
      "deb",
      "rpm",
      "appimage"
    ],
    "createUpdaterArtifacts": true,
    "publisher": "Magical Crocs",
    "copyright": "Copyright (c) 2026 MohamedSerhan (Magical Crocs)",
    "homepage": "https://github.com/MohamedSerhan/sts2-mod-manager",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Game",
    "shortDescription": "Mod manager for Slay the Spire 2 with frictionless sharing",
    "longDescription": "A cross-platform mod manager for Slay the Spire 2 that lets you install, manage, and share mod profiles with friends via shareable links.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "sts2mm"
        ]
      }
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/MohamedSerhan/sts2-mod-manager/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCRDJGQjAyQUQ1MDA4NkUKUldSdUNGQ3RBdnZTcTNjTzdJWFMrOWpQY1dGeTFScWcrcjI3RitkeEwrWE03OWZHY3l1V2t0NTMK"
    }
  }
}
